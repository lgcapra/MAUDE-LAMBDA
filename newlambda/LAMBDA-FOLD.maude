--- definition of higher-order fold (foldl) based on LAMBDA-DEF
--- the fold step is a binary lambda:  blambda elt, acc : body
--- type: FoldFun{X,Y} = BinFun{Iterable,Triv}{X,Y}
---
--- NOTE: why curried ARROW cannot be used
--- All attempts to express Arrow{acc, Arrow{elt,acc}} as a parametric type failed:
---
---   ARROW{Iterable, Y}{X,Y}               ← mixes theory-view (Iterable) and parameter (Y)
---   ARROW{Triv, InnerStep}{Y,X,Y}         ← InnerStep has 2 free params, each V consumes only 1
---   ARROW{Triv, InnerStep{X,Y}}{Y}        ← "nonfinal instantiation uses both theory-view and parameter"
---
--- Maude's constraint: no view expression (at any nesting level) can mix
--- named theory-views with module parameters. BINFUN{Iterable,Triv}{X,Y}
--- avoids this by having two separate 1-param theory-views, exactly as
--- ARROW{Iterable,Collection}{X,Y} does in MAP-ITE.
in LAMBDA-DEF
in LAMBDA-ITE

view InnerStep{X :: ITERABLE, Y :: TRIV} from TRIV to ARROW{Iterable, Triv}{X, Y} is
  sort Elt to Arrow{Iterable,Triv}{X,Y} .
endv

view InnerStep'{X :: COLLECTION', Y :: TRIV} from TRIV to ARROW{Collection', Triv}{X, Y} is
  sort Elt to Arrow{Collection',Triv}{X,Y} .
endv

fmod FOLD-ITE{X :: ITERABLE, Y :: TRIV} is
  protecting BINFUN{Iterable, Triv}{X, Y} *
    (sort BinFun{Iterable,Triv}{X,Y} to FoldFun{X,Y}) .

  op fold : [FoldFun{X,Y}] Y$Elt X$Coll -> [Y$Elt] .

  var f   : [FoldFun{X,Y}] .
  var acc : Y$Elt .
  var l   : X$Coll .

  eq fold(f, acc, X$nil) = acc .
  eq fold(f, acc, l)     = fold(f, apply2(f, get(l), acc), remainder(l)) .
endfm

fmod FOLD-COLL{X :: COLLECTION, Y :: TRIV} is
  protecting FOLD-ITE{IteColl, Triv}{X, Y} *
    (sort FoldFun{IteColl,Triv}{X,Y} to FoldFun{X,Y}) .
endfm

fmod FOLD-SAME-COLL{X :: COLLECTION} is
  protecting FOLD-COLL{IdeColl, Collection}{X, X} *
    (sort FoldFun{IdeColl,Collection}{X,X} to FoldFun{X}) .
endfm

fmod FOLD-COLL'{X :: COLLECTION', Y :: TRIV} is
  protecting BINFUN{Collection', Triv}{X, Y} *
    (sort BinFun{Collection',Triv}{X,Y} to FoldFun{X,Y}) .

  op fold : [FoldFun{X,Y}] Y$Elt X$Coll -> [Y$Elt] .

  var f   : [FoldFun{X,Y}] .
  var acc : Y$Elt .
  var e   : X$Elt .
  var l   : X$Coll .

  eq fold(f, acc, X$nil) = acc .
  eq fold(f, acc, (l e)) = fold(f, apply2(f, e, acc), l) .  --- constructor decomp (coherence assumed)
endfm

fmod FOLD-SAME-COLL'{X :: COLLECTION'} is
  protecting FOLD-COLL'{IdeColl', Collection'}{X, X} *
    (sort FoldFun{IdeColl',Collection'}{X,X} to FoldFun{X}) .
endfm

fmod FOLD-ITE'{X :: ITERABLE', Y :: TRIV} is
  protecting FOLD-COLL'{CollToIte', Triv}{X, Y} *
    (sort FoldFun{CollToIte',Triv}{X,Y} to FoldFun{X,Y}) .

  op fold : [FoldFun{X,Y}] Y$Elt X$Iterable -> [Y$Elt] .

  var f   : [FoldFun{X,Y}] .
  var acc : Y$Elt .
  var l   : X$Iterable .

  eq fold(f, acc, l) = fold(f, acc, iterator(l)) .
endfm
