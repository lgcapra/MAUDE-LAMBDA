--- map an ELIST into another

fmod EX6' is
  protecting MAP-ASCOLL{ElistAsColl{Float}, ElistColl{String}} * (sort Arrow{ElistAsColl{Float}, ElistColl{String}} to Arrow{Float,String}) .
  protecting CONVERSION .
  op toString  : Float -> Arrow{Float, String} .
  var x : Float .
  eq toString(x) = lambda x : string(x) .
endfm

red in EX6' : map(toString(x), [ 1.0 2.0 3.0 1.0 2.0 3.0 ]) .

fmod EX7' is
  protecting MAP-COLL'{ListColl{String}, SetColl{Nat}} * (sort Arrow{ListColl{String}, SetColl{Nat}} to Arrow{String, Nat}) .
  op toLen  : String -> Arrow{String, Nat} .
  var x : String .
  eq toLen(x) = lambda x : length(x) .
endfm

red in EX7' : map(toLen(x), "1" "2" "3" "4" "0" "9" "8" "10" "100" nil  "1" "2" "3" "4" "0" "9" "8" "10" "100" nil
        "1" "2" "3" "4" "0" "9" "8" "10" "100" nil  "1" "2" "3" "4" "0" "9" "8" "10" "100" nil
        "1" "2" "3" "4" "0" "9" "8" "10" "100" nil  "1" "2" "3" "4" "0" "9" "8" "10" "100" nil
        "1" "2" "3" "4" "0" "9" "8" "10" "100" nil  "1" "2" "3" "4" "0" "9" "8" "10" "100" nil
        "1" "2" "3" "4" "0" "9" "8" "10" "100" nil  "1" "2" "3" "4" "0" "9" "8" "10" "100" nil) .

red in EX7' : map(toLen(x), "cat" "dog" "Tiger" "Shark" "Snake" "leopard" "lion") .
red in EX7' : map(lambda x:Char : ascii(x:Char),  "a" "d" "T" "S") .


--- example of non-trivial lambda substitution 

--- reduce in EX3 : subst('X:String, upTerm(Y:String + "b"), upTerm(lambda Y:String : X:String + Y:String + "a")) .

--- down term of the substitution above

--- reduce in EX3 : downTerm(
---                    subst('X:String, upTerm(Y:String + "b"), upTerm(lambda Y:String : X:String + Y:String + "a")),
---                     lambda Z:String : Z:String) .
